# Backend Production Environment Variables
APP_SECRET_STRING=YourVerySecureSecretKeyForProduction
DATABASE_USERNAME=prototype_user
DATABASE_PASSWORD=YourSecurePasswordHere
DATABASE=prototype_prod
DATABASE_HOST=mysql-prod
DATABASE_PORT=3306

# Security settings
CORS_ORIGINS=["https://your-frontend-domain.com"]
ALLOWED_HOSTS=["your-api-domain.com"]

# Logging
LOG_LEVEL=INFO
DEBUG=false

# JWT Settings
JWT_SECRET_KEY=YourJWTSecretKeyHere
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# SSL/HTTPS
USE_SSL=true
